{
  "name": "climate-comfort-card",
  "version": "0.3.0-beta.1",
  "description": "A Home Assistant Lovelace card that plots temperature/humidity points on a comfort chart with per-room comfort zones and status evaluation.",
  "type": "module",
  "main": "dist/climate-comfort-card.js",
  "module": "dist/climate-comfort-card.js",
  "license": "MIT",
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "hacs",
    "climate",
    "comfort",
    "temperature",
    "humidity"
  ],
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "custom-card-helpers": "^1.9.0",
    "lit": "^3.1.4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "rollup": "^4.18.1",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3"
  }
}
